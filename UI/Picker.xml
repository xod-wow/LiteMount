<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\..\FrameXML\UI.xsd">

<Script file="Picker.lua" />

<Button name="LiteMountPickerMountButtonTemplate" virtual="true" inherits="LiteMountListItemStyleTemplate">
    <Size y="22" />
    <NormalFont style="GameFontNormal" />
    <ButtonText justifyH="LEFT" wordWrap="false">
        <Anchors>
            <Anchor point="LEFT" x="8" />
            <Anchor point="RIGHT" x="-8" />
        </Anchors>
    </ButtonText>
    <HighlightTexture alphaMode="ADD">
        <Color r="0.3" g="0.5" b="1" a="0.3" />
    </HighlightTexture>
</Button>

<Button name="LiteMountPickerButtonTemplate" virtual="true">
    <Size y="22" />
    <Frames>
        <Button parentArray="mount" inherits="LiteMountPickerMountButtonTemplate" />
        <Button parentArray="mount" inherits="LiteMountPickerMountButtonTemplate" />
        <Button parentArray="mount" inherits="LiteMountPickerMountButtonTemplate" />
    </Frames>
</Button>

<Frame name="LiteMountPicker" mixin="LiteMountPickerMixin" inherits="LiteMountPopOverPanelTemplate" hidden="true">
    <Size x="580" y="420" />
    <Anchors>
        <Anchor point="CENTER" y="80" />
    </Anchors>
    <Frames>
        <Button inherits="UIPanelCloseButton">
            <Anchors>
                <Anchor point="TOPRIGHT" x="-6" y="-6" />
            </Anchors>
        </Button>
        <ScrollFrame parentKey="Scroll" inherits="WoWScrollBoxList">
            <Anchors>
                <Anchor point="TOPLEFT" x="8" y="-42" />
                <Anchor point="BOTTOMRIGHT" x="-28" y="8" />
            </Anchors>
        </ScrollFrame>
        <EventFrame parentKey="ScrollBar" inherits="MinimalScrollBar" frameStrata="HIGH">
            <KeyValues>
                <KeyValue key="hideIfUnscrollable" value="false" type="boolean" />
            </KeyValues>
            <Anchors>
                <Anchor point="TOPRIGHT" relativeKey="$parent.Scroll" x="8" y="-2"/>
                <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Scroll" x="8" y="2"/>
            </Anchors>
        </EventFrame>
    </Frames>
</Frame>

</Ui>
